#!/bin/sh
# Pre-commit hook for Go CLI projects
# This hook runs formatting and linting before allowing commits

echo "Running pre-commit checks..."

# Check if we're in the root of a Go project
if [ ! -f "go.mod" ]; then
    echo "Error: go.mod not found. Are you in the project root?"
    exit 1
fi

# Run go fmt
echo "  → Running go fmt..."
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
    echo "Error: The following files need formatting:"
    echo "$unformatted"
    echo "Run 'make format' to fix."
    exit 1
fi

# Run go vet
echo "  → Running go vet..."
if ! go vet ./...; then
    echo "Error: go vet found issues."
    exit 1
fi

# Run tests
echo "  → Running tests..."
if ! go test -short ./...; then
    echo "Error: Tests failed."
    exit 1
fi

echo "All checks passed!"
exit 0
